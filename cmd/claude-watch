#!/usr/bin/env bash

set -euo pipefail

source "$(cd "$(dirname "$0")" && pwd)/lib/common.sh"

readonly MODE="$(parse_mode "$@")"
readonly FOLLOW="$(should_follow "$@")"
readonly PANE_PID="$(parse_pane_pid "$@")"
readonly POLL_INTERVAL="${AI_SESSION_POLL_INTERVAL:-0.1}"

cleanup_watch() {
  trap - EXIT INT TERM
  rm -f "$FIFO"
  rm -rf "$WATCHED_DIR"
  stop_background_jobs
}

format_stream() {
  case "$MODE" in
    summary)
      jq -Rr '
        def clean:
          gsub("[\r\n]+"; " ")
          | gsub("[[:space:]]+"; " ")
          | sub("^ +"; "")
          | sub(" +$"; "");

        def clip($n):
          if length > $n then .[0:($n - 3)] + "..." else . end;

        def headline($text; $n):
          ($text | clean
           | if test("[。.!?]") then match("^[^。.!?]+[。.!?]?").string else . end
           | clip($n));

        def text_summary($content; $n):
          if ($content | type) == "string" then
            ($content | headline(.; $n))
          elif ($content | type) == "array" then
            ([ $content[]? | select(.type == "text") | (.text // "") ] | join(" ") | headline(.; $n))
          else
            ""
          end;

        fromjson?
        | select(. != null)
        | (
            if .type == "assistant" then
              if ((.message.content // []) | length) > 0 then
                if .message.content[0].type == "tool_use" then
                  "tool\t\(.message.content[0].name // "?")"
                else
                  (text_summary(.message.content; 96) as $summary
                   | if $summary != "" then "reply\t\($summary)" else "assistant\tupdate" end)
                end
              else
                "assistant\tupdate"
              end
            elif .type == "user" then
              if (.message.content | type) == "array" and ((.message.content | length) > 0) and .message.content[0].type == "tool_result" then
                ""
              else
                (text_summary(.message.content; 96) as $summary
                 | if $summary != "" then "user\t\($summary)" else "user\t\(.message.content[0].type // "message")" end)
              end
            elif .type == "progress" then
              if .data.type == "query_update" then
                "search\t\((.data.query // "") | clean | clip(96))"
              elif .data.type == "search_results_received" then
                "search\t\((.data.resultCount // 0) | tostring) results"
              elif .data.type == "agent_progress" then
                "delegate\t\((.data.prompt // .data.message.message.content[0].text // "") | clean | clip(96))"
              elif .data.type == "hook_progress" then
                ""
              else
                "progress\t\(.data.type // "update")"
              end
            elif .type == "system" then
              "system\t\(.subtype // "event")"
            elif .type == "agent-setting" then
              "agent\t\(.agentSetting // "set")"
            else
              ""
            end
          ) as $summary
        | select($summary != "")
        | [
            ((.timestamp // "") | gsub(".*T|\\..*Z$"; "")),
            ((.sessionId // "")[0:8]),
            $summary
          ]
        | @tsv
      ' | redact_stream
      ;;
    details)
      jq -Rc '
        fromjson?
        | select(. != null)
        | {
            timestamp,
            sessionId,
            type,
            subtype,
            agentSetting,
            message
          }
      ' | jq . | redact_stream
      ;;
    raw)
      redact_stream
      ;;
    *)
      printf 'claude-watch: unknown mode: %s\n' "$MODE" >&2
      exit 1
      ;;
  esac
}

# ---- pane-pid mode ----
if [ -n "$PANE_PID" ]; then
  if [ "$FOLLOW" = "0" ]; then
    files="$(pane_claude_session_files "$PANE_PID")"
    if [ -z "$files" ]; then
      printf 'claude-watch: no active claude session in pane %s\n' "$PANE_PID" >&2
      exit 0
    fi
    while IFS= read -r file; do
      [ -n "$file" ] && tail -n 40 "$file"
    done <<< "$files" | format_stream
    exit 0
  fi

  FIFO="$(mktemp -u /tmp/claude-watch-XXXXXX)"
  WATCHED_DIR="$(mktemp -d /tmp/claude-watch-watched-XXXXXX)"
  mkfifo "$FIFO"
  trap cleanup_watch EXIT
  trap 'cleanup_watch; exit 130' INT
  trap 'cleanup_watch; exit 143' TERM

  exec 3<>"$FIFO"
  format_stream < "$FIFO" &

  start_tail_for_file() {
    local file="$1"
    local key
    key="$(printf '%s' "$file" | tr '/' '_')"
    local sentinel="$WATCHED_DIR/$key"
    [ -f "$sentinel" ] && return 0
    touch "$sentinel"
    tail -n 0 -F "$file" >> "$FIFO" &
    printf 'claude-watch: +%s\n' "$(claude_session_label "$file")" >&2
  }

  while true; do
    files="$(pane_claude_session_files "$PANE_PID")" || true
    while IFS= read -r file; do
      [ -n "$file" ] && start_tail_for_file "$file"
    done <<< "$files"
    sleep "$POLL_INTERVAL"
  done
  exit 0
fi

# ---- legacy mode (no --pane-pid) ----
SOURCE_FILE="$(latest_claude_project_log)"

if [ -z "$SOURCE_FILE" ] || [ ! -r "$SOURCE_FILE" ]; then
  printf 'claude-watch: source not readable\n' >&2
  exit 1
fi

if [ "$FOLLOW" = "1" ]; then
  tail -n 20 -F "$SOURCE_FILE"
else
  tail -n 20 "$SOURCE_FILE"
fi | format_stream
