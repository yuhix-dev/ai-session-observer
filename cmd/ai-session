#!/usr/bin/env bash

set -euo pipefail

readonly SESSION_NAME="${AI_SESSION_NAME:-ai-session}"
readonly DETACH_ONLY="${AI_SESSION_DETACH:-0}"
readonly SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
window_index=""

tmux_cmd() {
  env -u TMUX tmux "$@"
}

if tmux_cmd has-session -t "$SESSION_NAME" 2>/dev/null; then
  if [ "$DETACH_ONLY" = "1" ]; then
    exit 0
  fi
  exec env -u TMUX tmux attach-session -t "$SESSION_NAME"
fi

# Respect tmux pane-base-index (commonly 0 or 1)
PANE_BASE="$(tmux_cmd show-options -gv pane-base-index 2>/dev/null || echo 0)"
PANE_OP="$PANE_BASE"
PANE_CLAUDE="$((PANE_BASE + 1))"

tmux_cmd new-session -d -s "$SESSION_NAME"
window_index="$(tmux_cmd display-message -p -t "$SESSION_NAME" '#I')"

PANE0_TARGET="${SESSION_NAME}:${window_index}.${PANE_OP}"
tmux_cmd split-window -h -t "${SESSION_NAME}:${window_index}"
tmux_cmd send-keys -t "${SESSION_NAME}:${window_index}.${PANE_CLAUDE}" "\"${SCRIPT_DIR}/ai-session-observer\" --pane-target ${PANE0_TARGET}" C-m

if [ "$DETACH_ONLY" = "1" ]; then
  exit 0
fi

exec env -u TMUX tmux attach-session -t "$SESSION_NAME"
