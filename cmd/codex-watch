#!/usr/bin/env bash

set -euo pipefail

source "$(cd "$(dirname "$0")" && pwd)/lib/common.sh"

readonly MODE="$(parse_mode "$@")"
readonly FOLLOW="$(should_follow "$@")"
readonly PANE_PID="$(parse_pane_pid "$@")"
readonly POLL_INTERVAL="${AI_SESSION_POLL_INTERVAL:-0.1}"

cleanup_watch() {
  trap - EXIT INT TERM
  rm -f "$FIFO"
  rm -rf "$WATCHED_DIR"
  stop_background_jobs
}

format_stream() {
  case "$MODE" in
    summary)
      jq -Rr '
        def clean:
          gsub("[\r\n]+"; " ")
          | gsub("[[:space:]]+"; " ")
          | sub("^ +"; "")
          | sub(" +$"; "");

        def clip($n):
          if length > $n then .[0:($n - 3)] + "..." else . end;

        def headline($text; $n):
          ($text | clean
           | if test("[。.!?]") then match("^[^。.!?]+[。.!?]?").string else . end
           | clip($n));

        fromjson?
        | select(. != null)
        | (
            if .type == "event_msg" and .payload.type == "task_started" then
              "start\tturn \((.payload.turn_id // "")[0:8])"
            elif .type == "event_msg" and .payload.type == "task_complete" then
              "done\t\((.payload.last_agent_message // "") | headline(.; 110))"
            elif .type == "event_msg" and .payload.type == "agent_message" then
              "note\t\((.payload.message // "") | headline(.; 110))"
            elif .type == "event_msg" and .payload.type == "user_message" then
              "user\t\((.payload.message // "") | headline(.; 110))"
            elif .type == "event_msg" and .payload.type == "turn_aborted" then
              "abort\tturn"
            elif .type == "response_item" and .payload.type == "function_call" and .payload.name == "spawn_agent" then
              "spawn\t\(.payload.name)"
            else
              ""
            end
          ) as $summary
        | select($summary != "")
        | [
            ((.timestamp // "") | gsub(".*T|\\..*Z$"; "")),
            $summary
          ]
        | @tsv
      ' | redact_stream
      ;;
    details)
      jq -Rc '
        fromjson?
        | select(. != null)
        | {
            timestamp,
            type,
            payload
          }
      ' | jq . | redact_stream
      ;;
    raw)
      redact_stream
      ;;
    *)
      printf 'codex-watch: unknown mode: %s\n' "$MODE" >&2
      exit 1
      ;;
  esac
}

# ---- pane-pid mode ----
if [ -n "$PANE_PID" ]; then
  if [ "$FOLLOW" = "0" ]; then
    # One-shot: show last 20 lines of each currently open rollout file
    pane_codex_rollout_files "$PANE_PID" | while IFS= read -r f; do
      [ -n "$f" ] && tail -n 20 "$f"
    done | format_stream
    exit 0
  fi

  FIFO="$(mktemp -u /tmp/codex-watch-XXXXXX)"
  WATCHED_DIR="$(mktemp -d /tmp/codex-watch-watched-XXXXXX)"
  mkfifo "$FIFO"
  trap cleanup_watch EXIT
  trap 'cleanup_watch; exit 130' INT
  trap 'cleanup_watch; exit 143' TERM

  # Open FIFO in read+write mode (non-blocking) so the reader never gets EOF between writers
  exec 3<>"$FIFO"

  # Consumer: read merged stream and format
  format_stream < "$FIFO" &

  start_tail_for_file() {
    local file="$1"
    local key
    key="$(printf '%s' "$file" | tr '/' '_')"
    local sentinel="$WATCHED_DIR/$key"
    [ -f "$sentinel" ] && return 0
    touch "$sentinel"
    tail -n 0 -F "$file" >> "$FIFO" &
    local label
    label="$(codex_rollout_label "$file")"
    if [ -n "$label" ]; then
      printf 'codex-watch: +%s\n' "$label" >&2
    else
      printf 'codex-watch: +%s\n' "$(basename "$file")" >&2
    fi
  }

  while true; do
    files="$(pane_codex_rollout_files "$PANE_PID")" || true
    while IFS= read -r f; do
      [ -n "$f" ] && start_tail_for_file "$f"
    done <<< "$files"
    sleep "$POLL_INTERVAL"
  done
  exit 0
fi

# ---- legacy mode (no --pane-pid) ----
SOURCE_FILE="$(latest_codex_rollout)"

if [ -z "${SOURCE_FILE}" ] || [ ! -r "$SOURCE_FILE" ]; then
  printf 'codex-watch: latest rollout source not readable\n' >&2
  exit 1
fi

if [ "$FOLLOW" = "1" ]; then
  tail -n 20 -F "$SOURCE_FILE"
else
  tail -n 20 "$SOURCE_FILE"
fi | format_stream
