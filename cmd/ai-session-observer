#!/usr/bin/env bash

set -euo pipefail

readonly SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
readonly PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

if ! command -v go >/dev/null 2>&1; then
  printf 'ai-session-observer: missing command: go\n' >&2
  printf 'Install Go or keep using claude-watch/codex-watch for the legacy split view.\n' >&2
  exit 1
fi

exec go run "$PROJECT_ROOT/cmd/viewer" "$@"
